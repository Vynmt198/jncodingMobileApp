# Copy file này thành `.env` trong thư mục `mobileapp/`
# Lưu ý:
# - Android emulator: dùng 10.0.2.2 để trỏ về máy host
# - Máy thật: dùng IP LAN của máy tính (cùng Wi-Fi), ví dụ 192.168.3.193

# Android emulator (khuyến nghị)
EXPO_PUBLIC_API_BASE_URL_ANDROID_EMULATOR=http://10.0.2.2:3000/api

# Thiết bị thật (đổi IP theo máy bạn)
EXPO_PUBLIC_API_BASE_URL_DEVICE=http://192.168.3.193:3000/api

# (Optional) Web / fallback
API_BASE_URL=http://localhost:3000/api
